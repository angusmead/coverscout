# Hashed assets are content-addressed — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages must always revalidate so a fresh deploy isn't masked by a cached page.
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Loader-data manifest hash changes every build — never cache.
/static-loader-data-manifest-*.json
  Cache-Control: no-store

# Sitemap and robots can refresh on the daily side.
/sitemap.xml
  Cache-Control: public, max-age=3600, must-revalidate
/robots.txt
  Cache-Control: public, max-age=3600, must-revalidate
